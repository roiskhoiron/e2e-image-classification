   "source": [
    "# Data Ingestion & Validation\n",
    "\n",
    "This notebook downloads a public image dataset from Kaggle (fallback: creates dummy data),\n",
    "validates image files (removes corrupt/non-image), and splits into train/val/test (80/10/10)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import shutil\n",
    "from pathlib import Path\n",
    "\n",
    "RAW_DIR = Path(\"data/raw\")\n",
    "PROCESSED_DIR = Path(\"data/processed\")\n",
    "\n",
    "# --- 1. Download from Kaggle (if kagglehub available) ---\n",
    "try:\n",
    "    import kagglehub\n",
    "    path = kagglehub.dataset_download(\"your-org/your-dataset\")\n",
    "    print(f\"Downloaded dataset to {path}\")\n",
    "    RAW_DIR.mkdir(parents=True, exist_ok=True)\n",
    "    # Copy downloaded data to raw/ (adjust source path as needed)\n",
    "    for item in Path(path).iterdir():\n",
    "        dest = RAW_DIR / item.name\n",
    "        if item.is_dir():\n",
    "            shutil.copytree(item, dest, dirs_exist_ok=True)\n",
    "        else:\n",
    "            shutil.copy2(item, dest)\n",
    "except (ImportError, Exception) as e:\n",
    "    print(f\"Kaggle download skipped ({e}). Using existing data in {RAW_DIR}.\")\n",
    "\n",
    "# --- 2. Show what we have ---\n",
    "if RAW_DIR.exists():\n",
    "    classes = [p.name for p in sorted(RAW_DIR.iterdir()) if p.is_dir()]\n",
    "    print(f\"Found {len(classes)} class folders: {classes}\")\n",
    "    for cls in classes:\n",
    "        n = len(list((RAW_DIR / cls).glob(\"*\")))\n",
    "        print(f\"  {cls}: {n} files\")\n",
    "else:\n",
    "    print(f\"{RAW_DIR} does not exist. Create it and place class folders inside.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Validate & Split Dataset\n",
    "\n",
    "The `run_ingestion` function:\n",
    "- Scans all files in `data/raw/`, dropping corrupt / non-image files\n",
    - Splits per class into train/val/test (80/10/10)\n",
    "- Logs invalid files to `data/processed/ingestion_log.txt`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.data.dataset_builder import run_ingestion, scan_dataset\n",
    "\n",
    "if RAW_DIR.exists() and any(RAW_DIR.iterdir()):\n",
    "    valid, invalid = scan_dataset(RAW_DIR)\n",
    "    print(f\"Valid images: {len(valid)}\")\n",
    "    print(f\"Invalid/corrupt: {len(invalid)}\")\n",
    "    run_ingestion(\n",
    "        raw_dir=str(RAW_DIR),\n",
    "        processed_dir=str(PROCESSED_DIR),\n",
    "        log_path=\"data/processed/ingestion_log.txt\",\n",
    "    )\n",
    "else:\n",
    "    print(f\"No data in {RAW_DIR}. Place class subfolders with images and re-run.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### EDA — Class Distribution After Split"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "if PROCESSED_DIR.exists():\n",
    "    counts = {}\n",
    "    for split in [\"train\", \"val\", \"test\"]:\n",
    "        split_dir = PROCESSED_DIR / split\n",
    "        if split_dir.exists():\n",
    "            for cls_dir in sorted(split_dir.iterdir()):\n",
    "                if cls_dir.is_dir():\n",
    "                    key = f\"{split}/{cls_dir.name}\"\n",
    "                    counts[key] = len(list(cls_dir.glob(\"*\")))\n",
    "\n",
    "    labels, values = zip(*counts.items())\n",
    "    plt.figure(figsize=(10, 5))\n",
    "    plt.bar(labels, values)\n",
    "    plt.xticks(rotation=45, ha=\"right\")\n",
    "    plt.ylabel(\"Count\")\n",
    "    plt.title(\"Dataset Split — Images per Class\")\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(\"reports/figures/dataset_split.png\", dpi=150)\n",
    "    plt.show()\n",
    "    print(\"Saved dataset split chart to reports/figures/dataset_split.png\")\n",
    "else:\n",
    "    print(\"No processed data yet.\")"
   ]
  }
